{
  "name": "@vitest/snapshot",
  "type": "module",
  "version": "5.0.0-beta.1",
  "description": "Vitest snapshot manager",
  "license": "MIT",
  "funding": "https://opencollective.com/vitest",
  "homepage": "https://vitest.dev/guide/snapshot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitest-dev/vitest.git",
    "directory": "packages/snapshot"
  },
  "bugs": {
    "url": "https://github.com/vitest-dev/vitest/issues"
  },
  "keywords": [
    "vitest",
    "test",
    "snapshot"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "__vitest_source__": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./environment": {
      "__vitest_source__": "./src/environment.ts",
      "types": "./dist/environment.d.ts",
      "default": "./dist/environment.js"
    },
    "./manager": {
      "__vitest_source__": "./src/manager.ts",
      "types": "./dist/manager.d.ts",
      "default": "./dist/manager.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "*.d.ts",
    "dist"
  ],
  "scripts": {
    "build": "premove dist && rollup -c",
    "dev": "rollup -c --watch"
  },
  "dependencies": {
    "@vitest/pretty-format": "workspace:*",
    "@vitest/utils": "workspace:*",
    "magic-string": "catalog:",
    "pathe": "catalog:"
  },
  "devDependencies": {
    "@types/natural-compare": "^1.4.3",
    "natural-compare": "^1.4.0"
  }
}
